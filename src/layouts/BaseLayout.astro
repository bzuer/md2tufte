---
import "katex/dist/katex.min.css";
import { createHash } from "node:crypto";
import { readFileSync } from "node:fs";
import { fileURLToPath } from "node:url";

const { title = "Bruno Cruz" } = Astro.props;
const cssPath = (() => {
  if (import.meta.env.DEV) {
    return `/static/css/styles.dev.css?v=${Date.now()}`;
  }

  const minCssUrl = new URL(
    "../../public/static/css/styles.min.css",
    import.meta.url
  );
  const minCssPath = fileURLToPath(minCssUrl);
  const minCss = readFileSync(minCssPath, "utf8");
  const hash = createHash("sha256").update(minCss).digest("hex").slice(0, 8);

  return `/static/css/styles.min.css?v=${hash}`;
})();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href={cssPath} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <main id="content">
      <article>
        <section>
          <slot />
        </section>
      </article>
    </main>
    <script src="/static/js/main.min.js" defer></script>
  </body>
</html>
